---
import { t } from '../../i18n/utils';

interface Props {
  locale?: string;
}

const { locale = "en" } = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="max-w-4xl mx-auto px-6 md:px-8">
    <hr class="rule mb-12" />

    <p class="font-mono text-(--color-muted) text-xs tracking-widest uppercase mb-4">{t("community.label", locale)}</p>
    <h2 class="font-display text-2xl md:text-3xl leading-snug tracking-tight mb-6">
      {t("community.headline", locale)}
    </h2>
    <p class="text-(--color-text-secondary) leading-relaxed mb-8 max-w-xl">
      {t("community.description", locale)}
    </p>

    <a
      href="https://www.skool.com/ctx/about"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-6 py-3 text-base font-medium text-(--color-bg) bg-(--color-accent) hover:bg-(--color-accent-hover) rounded-lg transition-colors group"
    >
      <span>{t("community.cta", locale)}</span>
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
