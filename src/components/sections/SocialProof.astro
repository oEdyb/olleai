---
import { t } from '../../i18n/utils';
import Sprite from '../Sprite.astro';

interface Props {
  locale?: string;
}

const { locale = "en" } = Astro.props;

const channels = [
  {
    platform: "YouTube",
    handle: "@olleai",
    stat: t("socialproof.yt.stat", locale),
    href: "https://youtube.com/@olleai",
    color: "text-[#FF0000]",
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814Z"/><path d="m9.545 15.568 6.272-3.568-6.272-3.568v7.136Z" fill="var(--color-bg)"/></svg>`,
  },
  {
    platform: "TikTok",
    handle: "@olleai",
    stat: t("socialproof.tt.stat", locale),
    href: "https://tiktok.com/@olleai",
    color: "",
    icon: `<svg viewBox="0 0 24 24" class="w-7 h-7"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.89 2.89 2.89 0 0 1 2.88-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.33 6.33A6.34 6.34 0 0 0 9.49 21.62a6.34 6.34 0 0 0 6.33-6.33V8.73a8.19 8.19 0 0 0 4.77 1.52V6.8a4.84 4.84 0 0 1-1-.11Z" fill="#25F4EE" transform="translate(-0.5, -0.3)"/><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.89 2.89 2.89 0 0 1 2.88-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.33 6.33A6.34 6.34 0 0 0 9.49 21.62a6.34 6.34 0 0 0 6.33-6.33V8.73a8.19 8.19 0 0 0 4.77 1.52V6.8a4.84 4.84 0 0 1-1-.11Z" fill="#FE2C55" transform="translate(0.5, 0.3)"/><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.89 2.89 2.89 0 0 1 2.88-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.33 6.33A6.34 6.34 0 0 0 9.49 21.62a6.34 6.34 0 0 0 6.33-6.33V8.73a8.19 8.19 0 0 0 4.77 1.52V6.8a4.84 4.84 0 0 1-1-.11Z" fill="#e8e6e1"/></svg>`,
  },
  {
    platform: "X",
    handle: "@olledyberg",
    stat: t("socialproof.x.stat", locale),
    href: "https://x.com/olledyberg",
    color: "text-(--color-text)",
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<section class="py-12 md:py-16 relative sprite-wrapper overflow-hidden">
  <Sprite type="fish" class="top-4 left-[25%]" />
  <Sprite type="heart" class="bottom-6 right-[30%]" />

  <div class="max-w-4xl mx-auto px-6 md:px-8">
    <p class="text-(--color-text-secondary) text-lg leading-relaxed mb-8">{t("socialproof.label", locale)}</p>

    <div class="grid sm:grid-cols-3 gap-4">
      {channels.map((ch) => (
        <a
          href={ch.href}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card group flex items-center gap-4 p-5 min-h-14 rounded-lg border border-(--color-border) hover:border-(--color-border-hover) bg-(--color-surface) hover:bg-(--color-surface-hover)"
        >
          <div class:list={["social-icon flex-shrink-0", ch.color]} set:html={ch.icon} />
          <div class="min-w-0">
            <p class="text-sm font-medium text-(--color-text) group-hover:text-(--color-accent) transition-colors truncate">{ch.handle}</p>
            <p class="font-mono text-xs text-(--color-muted) tracking-wide">{ch.stat}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
