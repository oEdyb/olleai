---
import { t } from '../../i18n/utils';
import Sprite from '../Sprite.astro';

interface Props {
  locale?: string;
}

const { locale = "en" } = Astro.props;

const roles = [
  t("hero.role1", locale),
  t("hero.role2", locale),
  t("hero.role3", locale),
  t("hero.role4", locale),
  t("hero.role1", locale),
];
---

<section class="min-h-[100svh] pt-32 pb-8 md:pt-40 md:pb-12 relative sprite-wrapper overflow-hidden flex flex-col">
  <Sprite type="terminal" class="top-44 right-[12%] lg:right-[18%]" />
  <Sprite type="cat" class="bottom-28 left-[8%] lg:left-[16%]" />
  <Sprite type="sparkle" class="top-36 right-[38%]" />
  <Sprite type="coffee" class="top-52 left-[8%] lg:left-[14%]" />
  <Sprite type="robot" class="top-[40%] right-[8%] lg:right-[12%]" />
  <Sprite type="ghost" class="bottom-[35%] left-[5%] lg:left-[10%]" />
  <Sprite type="brackets" class="top-28 left-[30%] lg:left-[35%]" />
  <Sprite type="fish" class="bottom-20 right-[25%] lg:right-[30%]" />

  <div class="max-w-4xl mx-auto px-6 md:px-8 flex-1 flex flex-col justify-center">
    <!-- Photo with tag -->
    <div class="animate-reveal mb-8 md:mb-10">
      <div class="relative inline-block">
        <img
          src="/olle.webp"
          alt="Olle Dyberg"
          width="104"
          height="104"
          fetchpriority="high"
          class="hero-photo w-24 h-24 md:w-28 md:h-28 rounded-2xl object-cover border border-(--color-border)"
        />
        <span class="hero-tag absolute -bottom-2.5 -right-3 font-mono text-[11px] text-(--color-accent) bg-(--color-surface) px-2 py-0.5 border border-(--color-border) rounded-md select-none">
          @olleai
        </span>
      </div>
    </div>

    <!-- Name -->
    <h1 class="animate-reveal delay-1 font-display text-[2.5rem] md:text-[5.5rem] lg:text-[7rem] leading-[0.92] font-normal tracking-tight mb-5 md:mb-6">
      {t("hero.headline", locale)}
    </h1>

    <!-- Rotating roles -->
    <div class="animate-reveal delay-1 mb-10 md:mb-14 h-6 overflow-hidden">
      <div class="hero-roles">
        {roles.map((role) => (
          <span class="block h-6 leading-6 font-mono text-(--color-accent) text-sm md:text-base tracking-widest uppercase">
            {role}
          </span>
        ))}
      </div>
    </div>

    <!-- Subheadline + CTA -->
    <div class="animate-reveal delay-2 max-w-xl">
      <p class="text-(--color-text-secondary) text-lg md:text-xl leading-relaxed mb-10">
        {t("hero.subheadline", locale)}
      </p>

      <a
        href={locale === "en" ? "/consulting" : `/${locale}/consulting`}
        class="inline-flex items-center gap-3 text-base font-medium text-(--color-accent) border-b border-(--color-accent)/40 pb-0.5 hover:border-(--color-accent) transition-colors group"
      >
        <span>{t("hero.cta", locale)}</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="animate-reveal delay-3 flex flex-col items-center gap-3 pb-4">
    <span class="font-mono text-xs tracking-[0.3em] uppercase text-(--color-muted)">scroll</span>
    <div class="scroll-indicator w-px h-12 bg-gradient-to-b from-(--color-muted)/60 to-transparent"></div>
  </div>
</section>
